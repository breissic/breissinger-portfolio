---
const projects = [
  {
    title: 'Phonauto',
    subtitle: 'Music AI Assistant',
    description:
      'AI music generation with natural language composition, Monaco editor, per-track mixer, and visual timeline editing. Won Best Overall and People\'s Choice at MSU AI Club showcase.',
    tags: ['Next.js', 'FastAPI', 'PyTorch', 'Tone.js', 'Docker'],
    award: "Best Overall & People's Choice",
    github: 'https://github.com/maxwmeadow/music-ai-assistant',
    highlight: true,
  },
  {
    title: 'Project Helios',
    subtitle: 'SpartaHack 11',
    description:
      'Assistive navigation for blind users. YOLO11 object detection from mobile camera with spatial awareness, Gemini AI conversational guidance, and haptic feedback for hazard alerts.',
    tags: ['React Native', 'FastAPI', 'YOLO11', 'Gemini', 'Socket.IO'],
    award: 'SpartaHack 11',
    github: 'https://github.com/kendalleasterly/project-helios-spartahack',
    highlight: true,
  },
  {
    title: 'jupyter_tui',
    subtitle: null,
    description:
      'Terminal Jupyter notebook editor in Rust. Vim-style modal editing, live kernel execution over ZMQ, syntax highlighting, and inline image rendering via Kitty graphics protocol.',
    tags: ['Rust', 'ZMQ', 'TUI', 'Kernel Protocol'],
    github: 'https://github.com/breissic/jupyter-tui',
    highlight: false,
  },
  {
    title: 'Vehicle Damage Assessment',
    subtitle: 'Auto Owners Insurance × MSU AI Club',
    description:
      'Instance segmentation pipeline using Mask R-CNN for vehicle damage identification, with multi-LLM integration (Claude, GPT-4, Gemini) for repair cost estimation. Industry project for Auto Owners Insurance.',
    tags: ['PyTorch', 'Mask R-CNN', 'FastAPI', 'React', 'Multi-LLM'],
    github: null,
    highlight: false,
  },
  {
    title: 'NFL Betting Model',
    subtitle: null,
    description:
      'Elo rating system with margin-of-victory adjustments, backtested across 1,675+ games. 63.7% win/loss accuracy — within 2.9% of Vegas.',
    tags: ['Python', 'pandas', 'SQLite', 'Statistics'],
    github: 'https://github.com/breissic/nfl-betting-model',
    highlight: false,
  },
];
---

<section id="projects" class="border-t border-border bg-white px-6 py-20">
  <div class="mx-auto max-w-5xl">
    <span class="inline-block rounded-full bg-red/10 px-3 py-1 text-xs font-bold uppercase tracking-wider text-red">
      Projects
    </span>

    <h2 class="mt-4 font-heading text-2xl font-extrabold text-dark sm:text-3xl">
      Things I've built
    </h2>

    <div class="mt-10 grid gap-4 md:grid-cols-2">
      {projects.map((project) => {
        const isLink = !!project.github;
        const Tag = isLink ? 'a' : 'div';
        const linkProps = isLink
          ? { href: project.github, target: '_blank', rel: 'noopener noreferrer' }
          : {};
        return (
          <Tag
            {...linkProps}
            class:list={[
              'group relative rounded-lg border bg-cream-light p-6 transition-all duration-200',
              isLink ? 'cursor-pointer' : '',
              project.highlight
                ? 'border-red/30 hover:border-red/60 hover:shadow-md md:col-span-2'
                : 'border-border hover:border-border-strong hover:shadow-sm',
            ]}
          >
            {project.highlight && (
              <div class="absolute top-0 left-0 right-0 h-1 rounded-t-lg bg-gradient-to-r from-red to-yellow"></div>
            )}

            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0 flex-1">
                <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
                  <h3 class="font-heading text-base font-bold text-dark">
                    {project.title}
                  </h3>
                  {project.subtitle && (
                    <span class="text-sm text-dark-subtle">{project.subtitle}</span>
                  )}
                  {project.award && (
                    <span class="inline-flex items-center gap-1 rounded-full bg-yellow-light px-2.5 py-0.5 text-xs font-semibold text-yellow">
                      <svg class="h-3 w-3" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                      </svg>
                      {project.award}
                    </span>
                  )}
                </div>
                <p class="mt-2 text-sm leading-relaxed text-dark-muted">{project.description}</p>
              </div>
              {isLink && (
                <svg
                  class="h-4 w-4 shrink-0 text-dark-subtle transition-all duration-200 group-hover:text-red group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" />
                </svg>
              )}
            </div>
            <div class="mt-4 flex flex-wrap gap-1.5">
              {project.tags.map((tag) => (
                <span class="rounded-md border border-border bg-white px-2.5 py-0.5 text-xs font-medium text-dark-secondary">
                  {tag}
                </span>
              ))}
            </div>
          </Tag>
        );
      })}
    </div>
  </div>
</section>
