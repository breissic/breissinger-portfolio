---
const skillGroups = [
  {
    label: 'Languages',
    color: 'bg-blue-light text-blue',
    skills: ['Python', 'TypeScript', 'JavaScript', 'Java', 'C++', 'Rust', 'SQL'],
  },
  {
    label: 'AI / ML',
    color: 'bg-red/10 text-red',
    skills: ['PyTorch', 'TensorFlow', 'Keras', 'YOLO', 'Mask R-CNN', 'Gemini', 'OpenAI'],
  },
  {
    label: 'Computational',
    color: 'bg-yellow-light text-yellow',
    skills: ['NumPy', 'pandas', 'Jupyter', 'Computational Modeling'],
  },
  {
    label: 'Web & Mobile',
    color: 'bg-green-50 text-green-700',
    skills: ['React', 'Next.js', 'React Native', 'FastAPI', 'Flask', 'NestJS', 'Tailwind CSS'],
  },
  {
    label: 'Tools & Infrastructure',
    color: 'bg-purple-50 text-purple-700',
    skills: ['Linux', 'Vim', 'Git', 'Docker', 'AWS', 'PostgreSQL', 'SQLite', 'Supabase'],
  },
];
---

<section id="skills" class="border-t border-border px-6 py-20">
  <div class="mx-auto max-w-5xl">
    <span class="inline-block rounded-full bg-blue-light px-3 py-1 text-xs font-bold uppercase tracking-wider text-blue">
      Skills
    </span>

    <h2 class="mt-4 font-heading text-2xl font-extrabold text-dark sm:text-3xl">
      What I work with
    </h2>

    <div class="mt-10 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {skillGroups.map((group) => (
        <div>
          <span class:list={['inline-block rounded-full px-2.5 py-0.5 text-xs font-bold', group.color]}>
            {group.label}
          </span>
          <div class="mt-3 flex flex-wrap gap-2">
            {group.skills.map((skill) => (
              <span class="cursor-default rounded-md border border-border bg-white px-3 py-1.5 text-sm font-medium text-dark-secondary transition-all duration-200 hover:border-border-strong hover:text-dark hover:shadow-sm">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
