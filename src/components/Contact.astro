---

<section id="contact" class="px-6 py-24">
  <div class="mx-auto max-w-4xl">
    <h2 class="font-heading text-sm font-medium uppercase tracking-widest text-slate-500">
      Contact
    </h2>

    <div class="mt-8">
      <p class="max-w-lg text-slate-400">
        Looking for internship and full-time opportunities.
        If you think I'd be a good fit, I'd like to hear from you.
      </p>

      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href="mailto:carson@breissinger.net"
          class="cursor-pointer inline-flex items-center gap-2 rounded-md bg-slate-100 px-5 py-2.5 text-sm font-medium text-slate-900 transition-colors duration-150 hover:bg-white"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          carson@breissinger.net
        </a>
        <a
          href="https://linkedin.com/in/carson-breissinger"
          target="_blank"
          rel="noopener noreferrer"
          class="cursor-pointer inline-flex items-center gap-2 rounded-md border border-slate-700 px-5 py-2.5 text-sm font-medium text-slate-300 transition-colors duration-150 hover:border-slate-500 hover:text-slate-100"
        >
          LinkedIn
        </a>
        <a
          href="https://github.com/breissic"
          target="_blank"
          rel="noopener noreferrer"
          class="cursor-pointer inline-flex items-center gap-2 rounded-md border border-slate-700 px-5 py-2.5 text-sm font-medium text-slate-300 transition-colors duration-150 hover:border-slate-500 hover:text-slate-100"
        >
          GitHub
        </a>
      </div>
    </div>
  </div>
</section>
