---

<section id="contact" class="border-t border-border bg-dark px-6 py-20">
  <div class="mx-auto max-w-5xl">
    <div class="max-w-lg">
      <span class="inline-block rounded-full bg-white/10 px-3 py-1 text-xs font-bold uppercase tracking-wider text-white/70">
        Contact
      </span>

      <h2 class="mt-4 font-heading text-2xl font-extrabold text-white sm:text-3xl">
        Let's talk<span class="text-red">.</span>
      </h2>

      <p class="mt-4 text-base leading-relaxed text-white/60">
        Looking for internship and full-time opportunities.
        If you think I'd be a good fit, I'd like to hear from you.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="mailto:carson@breissinger.net"
          class="cursor-pointer inline-flex items-center gap-2 rounded-md bg-red px-5 py-2.5 text-sm font-semibold text-white transition-all duration-200 hover:bg-red-light hover:shadow-lg"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          carson@breissinger.net
        </a>
        <a
          href="https://linkedin.com/in/carson-breissinger"
          target="_blank"
          rel="noopener noreferrer"
          class="cursor-pointer inline-flex items-center gap-2 rounded-md border border-white/20 px-5 py-2.5 text-sm font-semibold text-white transition-all duration-200 hover:border-white/40 hover:bg-white/5"
        >
          LinkedIn
        </a>
        <a
          href="https://github.com/breissic"
          target="_blank"
          rel="noopener noreferrer"
          class="cursor-pointer inline-flex items-center gap-2 rounded-md border border-white/20 px-5 py-2.5 text-sm font-semibold text-white transition-all duration-200 hover:border-white/40 hover:bg-white/5"
        >
          GitHub
        </a>
      </div>
    </div>
  </div>
</section>

<footer class="bg-dark border-t border-white/10 px-6 py-6">
  <div class="mx-auto max-w-5xl flex items-center justify-between text-sm text-white/40">
    <span>Carson Breissinger</span>
  </div>
</footer>
