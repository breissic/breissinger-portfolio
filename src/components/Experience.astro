---
const experiences = [
  {
    role: 'Software Developer Intern',
    company: 'SpendMatch, Inc.',
    period: 'Current',
    description:
      'Building production software for the SpendMatch platform as part of the engineering team.',
    tags: ['TypeScript', 'React', 'Full-Stack'],
    current: true,
  },
  {
    role: 'Software Developer',
    company: 'MSU AI Club — Advanced Projects',
    period: 'Aug 2025 — Present',
    description:
      'Currently building a vehicle damage assessment pipeline for Auto Owners Insurance using Mask R-CNN and multi-LLM cost estimation. Previously developed Phonauto (Music AI Assistant), which won Best Overall and People\'s Choice.',
    tags: ['PyTorch', 'Next.js', 'FastAPI', 'Computer Vision'],
    current: true,
  },
  {
    role: 'Student Intern',
    company: 'The Global Career Accelerator',
    period: 'Sep 2024 — Dec 2024',
    description:
      'Extracted insights from enterprise datasets using SQL and Python. Built visualizations identifying market trends and consumer demand patterns.',
    tags: ['SQL', 'Python', 'Data Analysis', 'Tableau'],
    current: false,
  },
];
---

<section id="experience" class="border-t border-border px-6 py-20">
  <div class="mx-auto max-w-5xl">
    <span class="inline-block rounded-full bg-yellow-light px-3 py-1 text-xs font-bold uppercase tracking-wider text-yellow">
      Experience
    </span>

    <h2 class="mt-4 font-heading text-2xl font-extrabold text-dark sm:text-3xl">
      Where I've worked
    </h2>

    <div class="mt-10 grid gap-4">
      {experiences.map((exp) => (
        <div class="group rounded-lg border border-border bg-white p-6 transition-all duration-200 hover:border-border-strong hover:shadow-sm">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div class="min-w-0 flex-1">
              <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                <h3 class="font-heading text-lg font-bold text-dark">{exp.role}</h3>
                {exp.current && (
                  <span class="inline-flex items-center gap-1.5 rounded-full bg-green-50 px-2.5 py-0.5 text-xs font-semibold text-green-700">
                    <span class="h-1.5 w-1.5 rounded-full bg-green-500"></span>
                    Current
                  </span>
                )}
              </div>
              <p class="mt-1 text-sm font-medium text-dark-muted">{exp.company}</p>
              <p class="mt-2 text-sm leading-relaxed text-dark-muted">{exp.description}</p>
            </div>
            <span class="shrink-0 rounded-full border border-border px-3 py-1 text-xs font-medium text-dark-subtle">
              {exp.period}
            </span>
          </div>
          <div class="mt-4 flex flex-wrap gap-2">
            {exp.tags.map((tag) => (
              <span class="rounded-md bg-cream px-2.5 py-1 text-xs font-medium text-dark-secondary">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
