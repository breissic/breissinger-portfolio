---
const links = [
  { label: 'About', href: '#about' },
  { label: 'Experience', href: '#experience' },
  { label: 'Projects', href: '#projects' },
  { label: 'Skills', href: '#skills' },
  { label: 'Contact', href: '#contact' },
];
---

<nav
  class="fixed top-4 left-4 right-4 z-50 mx-auto max-w-5xl"
  aria-label="Primary navigation"
>
  <div class="rounded-xl border border-subtle bg-slate-950/80 px-6 py-3 backdrop-blur-xl">
    <div class="flex items-center justify-between">
      <a
        href="#"
        class="font-heading text-lg font-bold text-slate-50 transition-colors duration-200 hover:text-emerald-400"
        aria-label="Back to top"
      >
        CB
      </a>

      <!-- Desktop nav -->
      <ul class="hidden items-center gap-1 md:flex" role="list">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              class="cursor-pointer rounded-lg px-3 py-1.5 text-sm font-medium text-slate-400 transition-colors duration-200 hover:bg-slate-800/60 hover:text-slate-50"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Mobile toggle -->
      <button
        id="mobile-toggle"
        class="cursor-pointer rounded-lg p-2 text-slate-400 transition-colors duration-200 hover:bg-slate-800/60 hover:text-slate-50 md:hidden"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <ul
      id="mobile-menu"
      class="mt-3 hidden flex-col gap-1 border-t border-subtle pt-3 md:hidden"
      role="list"
    >
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="mobile-link block cursor-pointer rounded-lg px-3 py-2 text-sm font-medium text-slate-400 transition-colors duration-200 hover:bg-slate-800/60 hover:text-slate-50"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
    menu?.classList.toggle('flex');
  });

  document.querySelectorAll('.mobile-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      menu?.classList.remove('flex');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
