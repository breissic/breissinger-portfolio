---
const links = [
  { label: 'About', href: '#about' },
  { label: 'Experience', href: '#experience' },
  { label: 'Projects', href: '#projects' },
  { label: 'Skills', href: '#skills' },
  { label: 'Contact', href: '#contact' },
];
---

<nav
  class="fixed top-0 left-0 right-0 z-50 border-b border-border bg-cream/90 backdrop-blur-md"
  aria-label="Primary navigation"
>
  <div class="mx-auto max-w-5xl px-6">
    <div class="flex h-14 items-center justify-between">
      <a
        href="#"
        class="font-heading text-lg font-extrabold text-dark transition-colors duration-200 hover:text-red"
        aria-label="Back to top"
      >
        CB<span class="text-red">.</span>
      </a>

      <!-- Desktop nav -->
      <ul class="hidden items-center gap-1 md:flex" role="list">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              class="cursor-pointer rounded-md px-3 py-1.5 text-sm font-medium text-dark-muted transition-colors duration-200 hover:bg-cream-dark hover:text-dark"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Mobile toggle -->
      <button
        id="mobile-toggle"
        class="cursor-pointer rounded-md p-2 text-dark-muted transition-colors duration-200 hover:bg-cream-dark hover:text-dark md:hidden"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <ul
      id="mobile-menu"
      class="hidden flex-col gap-1 border-t border-border pb-3 pt-2 md:hidden"
      role="list"
    >
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="mobile-link block cursor-pointer rounded-md px-3 py-2 text-sm font-medium text-dark-muted transition-colors duration-200 hover:bg-cream-dark hover:text-dark"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
    menu?.classList.toggle('flex');
  });

  document.querySelectorAll('.mobile-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      menu?.classList.remove('flex');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
