<section id="about" class="border-t border-border bg-white px-6 py-20">
  <div class="mx-auto max-w-5xl">
    <span class="inline-block rounded-full bg-blue-light px-3 py-1 text-xs font-bold uppercase tracking-wider text-blue">
      About
    </span>

    <div class="mt-8 grid gap-10 md:grid-cols-5">
      <div class="md:col-span-3">
        <h2 class="font-heading text-2xl font-extrabold text-dark sm:text-3xl">
          Building at the crossroads of AI & software engineering
        </h2>
        <p class="mt-4 text-base leading-relaxed text-dark-muted">
          I'm a computer science student at <strong class="font-semibold text-dark">Michigan State University</strong>
          specializing in artificial intelligence, with minors in computational mathematics (CMSE)
          and business. I build things that sit at the crossroads of intelligent systems
          and practical software engineering.
        </p>
        <p class="mt-3 text-base leading-relaxed text-dark-muted">
          My work spans from award-winning AI music generation to real-time computer vision for
          accessibility, industry ML pipelines, and systems-level tools in Rust.
          I care about writing software that's both technically sound and genuinely useful.
        </p>
      </div>

      <div class="md:col-span-2">
        <div class="rounded-lg border border-border bg-cream-light p-6">
          <h3 class="text-xs font-bold uppercase tracking-wider text-dark-subtle mb-4">
            Quick Facts
          </h3>
          <dl class="space-y-3 text-sm">
            <div class="flex items-baseline justify-between gap-2">
              <dt class="text-dark-subtle">Education</dt>
              <dd class="font-medium text-dark">B.S. Computer Science, MSU</dd>
            </div>
            <div class="h-px bg-border"></div>
            <div class="flex items-baseline justify-between gap-2">
              <dt class="text-dark-subtle">GPA</dt>
              <dd class="font-medium text-dark">3.65</dd>
            </div>
            <div class="h-px bg-border"></div>
            <div class="flex items-baseline justify-between gap-2">
              <dt class="text-dark-subtle">Focus</dt>
              <dd class="font-medium text-dark">Artificial Intelligence</dd>
            </div>
            <div class="h-px bg-border"></div>
            <div class="flex items-baseline justify-between gap-2">
              <dt class="text-dark-subtle">Minors</dt>
              <dd class="font-medium text-dark">CMSE, Business</dd>
            </div>
            <div class="h-px bg-border"></div>
            <div class="flex items-baseline justify-between gap-2">
              <dt class="text-dark-subtle">Graduation</dt>
              <dd class="font-medium text-dark">May 2027</dd>
            </div>
            <div class="h-px bg-border"></div>
            <div class="flex items-baseline justify-between gap-2">
              <dt class="text-dark-subtle">Certification</dt>
              <dd class="font-medium text-dark">AWS Cloud Practitioner</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </div>
</section>
